# Copy this file to `.env` and fill in real values. Never commit `.env`.

# ─── Database ────────────────────────────────────────────────────────────────
# Supabase Postgres connection string. Use the Connection Pooler (port 6543)
# in serverless / Railway environments to avoid exhausting connections.
DATABASE_URL=postgres://postgres:[PASSWORD]@db.[PROJECT].supabase.co:6543/postgres

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
APP_VERSION=dev

# ─── Auth (custom, will be replaced by Supabase Auth — see ROADMAP.md) ───────
JWT_SECRET=replace-me-with-a-long-random-string
SESSION_SECRET=replace-me-with-another-long-random-string

# ─── Supabase (for auth migration and storage) ───────────────────────────────
SUPABASE_URL=https://[PROJECT].supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # NEVER expose to the client. Backend only.

# Feature flag: when "true" AND the two SUPABASE_* keys above are set, the
# backend mounts the Supabase Auth v2 routes at /api/auth/v2/*. The legacy
# /api/auth/* routes keep working in parallel until the cutover. Default
# off so existing deploys are unaffected.
SUPABASE_AUTH_ENABLED=false

# Public keys also exposed to the Vite frontend. Mirror SUPABASE_URL +
# SUPABASE_ANON_KEY here so the client can call supabase-js directly.
VITE_SUPABASE_URL=https://[PROJECT].supabase.co
VITE_SUPABASE_ANON_KEY=

# ─── Observability ───────────────────────────────────────────────────────────
SENTRY_DSN=

# ─── External integrations (optional, fill in only what you use) ─────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GCS_BUCKET_NAME=
GCS_PROJECT_ID=

# Open Banking providers (only if enabling banking features)
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=
TRUELAYER_CLIENT_ID=
TRUELAYER_CLIENT_SECRET=
TINK_CLIENT_ID=
TINK_CLIENT_SECRET=
SALTEDGE_APP_ID=
SALTEDGE_SECRET=
YAPILY_APPLICATION_ID=
YAPILY_APPLICATION_SECRET=
